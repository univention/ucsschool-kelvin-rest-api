#!/bin/bash
#
# This is a script for development.
# The tool inotifycopy can be found in the dev toolshed


TARGET=""
USE_STOPPED=""

for arg in "$@"; do
	case "$arg" in
		--stopped) USE_STOPPED=1 ;;
		*) TARGET="$arg" ;;
	esac
done

for tool in inotifycopy jq ssh ; do
	which "$tool" > /dev/null || {
		echo "ERROR: cannot find tool '$tool'."
		exit 1
	}
done

[ -z "$TARGET" ] && {
	echo "syntax: $(basename "$0") <host> [--stopped]"
	echo "Please specify the hostname or IP address as first argument."
	echo "Use --stopped to derive the target directory from a stopped Docker container"
	echo "(uses UpperDir instead of MergedDir)."
	exit 1
}

[ ! -d .git ] && {
	echo "ERROR: Please change to the root directory of the repo 'ucsschool-kelvin-rest-api'."
	exit 1
}

if [ -n "$USE_STOPPED" ]; then
	INSTANCE="$(ssh "root@$TARGET" docker ps -a | grep "ucsschool-kelvin-rest-api:" | cut -d" " -f1)"
	TARGETDIR="$(ssh "root@$TARGET" docker inspect "$INSTANCE" | jq .[0].GraphDriver.Data.UpperDir -r)"
	echo "Container (stopped): $INSTANCE"
	echo "Container dir: $TARGETDIR"

	[ -z "$INSTANCE" -o -z "$TARGETDIR" ] && {
		echo "ERROR: Cannot determine stopped docker container. Stopping here."
		exit 1
	}
else
	INSTANCE="$(ssh "root@$TARGET" docker ps | grep "ucsschool-kelvin-rest-api:" | cut -d" " -f1)"
	TARGETDIR="$(ssh "root@$TARGET" docker inspect "$INSTANCE" | jq .[0].GraphDriver.Data.MergedDir -r)"
	echo "Container: $INSTANCE"
	echo "Container dir: $TARGETDIR"

	[ -z "$INSTANCE" -o -z "$TARGETDIR" ] && {
		echo "ERROR: Cannot determine running docker container. Stopping here."
		exit 1
	}
fi

CONNECTOR_INSTANCE="$(ssh "root@$TARGET" docker ps | grep "ucsschool-kelvin-connector:" | cut -d" " -f1)"
CONNECTOR_TARGETDIR="$(ssh "root@$TARGET" docker inspect "$CONNECTOR_INSTANCE" | jq .[0].GraphDriver.Data.MergedDir -r)"
echo "Connector container: $CONNECTOR_INSTANCE"
echo "Connector container dir: $CONNECTOR_TARGETDIR"

[ -z "$CONNECTOR_INSTANCE" -o -z "$CONNECTOR_TARGETDIR" ] && {
  echo "ERROR: Cannot determine running connector docker container. Stopping here."
  exit 1
}

UCS_TEST_DIR="/usr/share/ucs-test/94_ucsschool-kelvin/"
if ! ssh "root@$TARGET" test -d "$UCS_TEST_DIR"; then
    echo "WARNING: $UCS_TEST_DIR does not exist, ucs-test-ucsschool-kelvin is not installed."
    ssh "root@$TARGET" "mkdir -p $UCS_TEST_DIR"
fi

inotifycopy \
	-a kelvin-api/tests/*.py:$TARGET:$TARGETDIR/kelvin/kelvin-api/tests/ \
	-a kelvin-api/ucsschool/kelvin/*.py:$TARGET:$TARGETDIR/kelvin/kelvin-api/ucsschool/kelvin/ \
	-a kelvin-api/ucsschool/kelvin/service/*.py:$TARGET:$TARGETDIR/kelvin/kelvin-api/ucsschool/kelvin/service/ \
	-a kelvin-api/ucsschool/kelvin/routers/*.py:$TARGET:$TARGETDIR/kelvin/kelvin-api/ucsschool/kelvin/routers/ \
	-a kelvin-api/ucsschool/kelvin/routers/v1/*.py:$TARGET:$TARGETDIR/kelvin/kelvin-api/ucsschool/kelvin/routers/v1/ \
	-a kelvin-api/ucsschool/kelvin/routers/v2/*.py:$TARGET:$TARGETDIR/kelvin/kelvin-api/ucsschool/kelvin/routers/v2/ \
	-a ucs-school-import/modules/ucsschool/importer/models/*.py:$TARGET:$TARGETDIR/kelvin/ucs-school-import/modules/ucsschool/importer/models/ \
	-a ucs-school-import/modules/ucsschool/importer/*.py:$TARGET:$TARGETDIR/kelvin/ucs-school-import/modules/ucsschool/importer/ \
	-a ucs-school-import/modules/ucsschool/importer/contrib/*.py:$TARGET:$TARGETDIR/kelvin/ucs-school-import/modules/ucsschool/importer/contrib/ \
	-a ucs-school-import/modules/ucsschool/importer/frontend/*.py:$TARGET:$TARGETDIR/kelvin/ucs-school-import/modules/ucsschool/importer/frontend/ \
	-a ucs-school-import/modules/ucsschool/importer/legacy/*.py:$TARGET:$TARGETDIR/kelvin/ucs-school-import/modules/ucsschool/importer/legacy/ \
	-a ucs-school-import/modules/ucsschool/importer/mass_import/*.py:$TARGET:$TARGETDIR/kelvin/ucs-school-import/modules/ucsschool/importer/mass_import/ \
	-a ucs-school-import/modules/ucsschool/importer/reader/*.py:$TARGET:$TARGETDIR/kelvin/ucs-school-import/modules/ucsschool/importer/reader/ \
	-a ucs-school-import/modules/ucsschool/importer/utils/*.py:$TARGET:$TARGETDIR/kelvin/ucs-school-import/modules/ucsschool/importer/utils/ \
	-a ucs-school-import/modules/ucsschool/importer/writer/*.py:$TARGET:$TARGETDIR/kelvin/ucs-school-import/modules/ucsschool/importer/writer/ \
	-a ucs-school-lib/modules/ucsschool/lib/*.py:$TARGET:$TARGETDIR/kelvin/ucs-school-lib/modules/ucsschool/lib/ \
	-a ucs-school-lib/modules/ucsschool/lib/models/*.py:$TARGET:$TARGETDIR/kelvin/ucs-school-lib/modules/ucsschool/lib/models/ \
	-a ucs-school-lib/modules/ucsschool/lib/pyhooks/*.py:$TARGET:$TARGETDIR/kelvin/ucs-school-lib/modules/ucsschool/lib/pyhooks/ \
	-a ucs-school-lib/modules/ucsschool/lib/tests/*.py:$TARGET:$TARGETDIR/kelvin/ucs-school-lib/modules/ucsschool/lib/tests/ \
	-a ucs-test-ucsschool-kelvin/94_ucsschool-kelvin/*.py:$TARGET:/usr/share/ucs-test/94_ucsschool-kelvin/ \
	-a kelvin-connector/src/kelvin_connector/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/kelvin-connector/src/kelvin_connector/ \
	-a kelvin-connector/tests/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/kelvin-connector/tests/ \
	-a ucsschool-objects/src/ucsschool_objects/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/src/ucsschool_objects/ \
	-a ucsschool-objects/src/ucsschool_objects/core/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/src/ucsschool_objects/core/ \
	-a ucsschool-objects/src/ucsschool_objects/core/adapters/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/src/ucsschool_objects/core/adapters/ \
	-a ucsschool-objects/src/ucsschool_objects/core/adapters/sqlalchemy/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/src/ucsschool_objects/core/adapters/sqlalchemy/ \
	-a ucsschool-objects/src/ucsschool_objects/core/adapters/sqlalchemy/managers/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/src/ucsschool_objects/core/adapters/sqlalchemy/managers/ \
	-a ucsschool-objects/src/ucsschool_objects/core/adapters/sqlalchemy/mappers/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/src/ucsschool_objects/core/adapters/sqlalchemy/mappers/ \
	-a ucsschool-objects/src/ucsschool_objects/core/domain/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/src/ucsschool_objects/core/domain/ \
	-a ucsschool-objects/src/ucsschool_objects/core/domain/ports/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/src/ucsschool_objects/core/domain/ports/ \
	-a ucsschool-objects/tests/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/tests/ \
	-a ucsschool-objects/tests/core/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/tests/core/ \
	-a ucsschool-objects/tests/core/adapters/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/tests/core/adapters/ \
	-a ucsschool-objects/tests/core/contracts/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/tests/core/contracts/ \
	-a ucsschool-objects/tests/core/domain/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/tests/core/domain/ \
	-a ucsschool-objects/tests/core/domain/helpers/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/tests/core/domain/helpers/ \
	-a ucsschool-objects/tests/test_database_models/*.py:$TARGET:$CONNECTOR_TARGETDIR/app/ucsschool-objects/tests/test_database_models/ \
	-i
