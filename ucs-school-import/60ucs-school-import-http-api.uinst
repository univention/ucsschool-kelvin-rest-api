## joinscript api: bindpwdfile

VERSION=1

. /usr/share/univention-join/joinscripthelper.lib
. /usr/share/univention-celery/celery.sh

joinscript_init

RABBITMQ_USER="importhttpapi"
RABBITMQ_VHOST="importhttpapi"

rabbitmq_remove_vhost "$RABBITMQ_USER" "$RABBITMQ_VHOST"

joinscript_remove_script_from_status_file ucs-school-import-http-api

exit 0
