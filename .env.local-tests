# Environment overrides for running the Kelvin test suite locally against a
# remote UCS server.
#
# Prerequisites:
#   make fetch-vm-data TARGET=<hostname>   # populates dev/_vm_config/
#
# Usage (via make target):
#   make local-tests
#
# Server/LDAP settings (DOCKER_HOST_NAME, LDAP_*, etc.) come from
# dev/_vm_config/env, which is written by fetch-vm-data.
#
# KELVIN_IN_CONTAINER is intentionally absent — without it the test fixtures
# that write server-side config files and restart the API are automatically
# skipped, which is correct when running against a remote server.

# Local Kelvin instance (gunicorn on localhost:8911 started separately)
# These override the remote host/port set in dev/_vm_config/env.
DOCKER_HOST_NAME=127.0.0.1
KELVIN_API_PORT=8911
KELVIN_API_SCHEME=http

# Secret / credential files (fetched by fetch-vm-data)
KELVIN_CN_ADMIN_PASSWORD_FILE=dev/_vm_config/ldap.secret
KELVIN_TOKEN_SIGN_SECRET_FILE=dev/_vm_config/tokens.secret
KELVIN_MACHINE_PASSWORD_FILE=dev/_vm_config/machine.secret

# Import config chain — required files point to repo-local copies
KELVIN_IMPORT_CONFIG_FILE_GLOBAL_DEFAULTS=ucs-school-import/usr/share/ucs-school-import/configs/global_defaults.json
KELVIN_IMPORT_CONFIG_FILE_USER_DEFAULTS=ucs-school-import/usr/share/ucs-school-import/configs/user_import_defaults.json
KELVIN_IMPORT_CONFIG_CHECKS_DIR=ucs-school-import/usr/share/ucs-school-import/checks
# Optional files fetched by fetch-vm-data (skipped automatically if absent)
KELVIN_IMPORT_CONFIG_FILE_USER_IMPORT=dev/_vm_config/user_import.json
KELVIN_IMPORT_CONFIG_FILE_DEFAULT=dev/_vm_config/kelvin_defaults.json
KELVIN_IMPORT_CONFIG_FILE_USER=dev/_vm_config/kelvin.json

# Other config files
KELVIN_UDM_MAPPED_PROPERTIES_CONFIG_FILE=dev/_vm_config/mapped_udm_properties.json
UCSSCHOOL_KELVIN_DB_PASSWORDFILE=dev/_vm_config/postgresql-kelvin.secret
UCSSCHOOL_KELVIN_DB_URI=postgresql://localhost:5432/ucsschool-kelvin-rest-api?sslmode=disable
UCSSCHOOL_KELVIN_DB_USERNAME=ucsschool-kelvin-rest-api

# Hooks directories (created by fetch-vm-data)
KELVIN_IMPORTUSER_HOOKS_PATH=dev/_vm_config/kelvin-hooks
KELVIN_SCHOOL_LIB_HOOKS_PATH=dev/_vm_config/school-lib-hooks

# Static files — repo-local copy
KELVIN_STATIC_FILES_PATH=kelvin-api/static

# UCR config file (fetched from VM by fetch-vm-data)
UNIVENTION_BASECONF=dev/_vm_config/base.conf

# UCS server certificates
REQUESTS_CA_BUNDLE=dev/_vm_config/ca-certificates.crt
SSL_CERT_FILE=dev/_vm_config/ca-certificates.crt
